# Environment Mode: local (use local model files) or cloud (use Hugging Face Inference API)
EMBEDDING_MODE=local

# Required for EMBEDDING_MODE=cloud
HF_TOKEN=your_huggingface_read_token_here

# Port to listen on (Render provides this automatically)
PORT=3009

# Model Configuration
EMBEDDING_MODEL_KEY=bge-small

# Data Paths (Optional - use these if not using the default ./data snapshot)
# BE3_AI_PATH=C:\Users\chatz\Downloads\eCommerce\be3_ai
